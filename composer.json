{
    "name": "robinsonryan/yikes",
    "description": "In-app dev/QC note capture for any Laravel app: a self-contained FAB + element picker writing flat-file notes for AI-assisted processing",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "RobinsonRyan\\Yikes\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RobinsonRyan\\Yikes\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/routing": "^12.0|^13.0",
        "symfony/yaml": "^7.0|^8.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "orchestra/testbench": "^10.0|^11.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "RobinsonRyan\\Yikes\\YikesServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
